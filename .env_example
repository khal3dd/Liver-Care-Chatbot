# ══════════════════════════════════════════════════════════════════════════════
#  .env_example — Environment Variables Template
#  
#  Copy this file to .env and fill in your values
#  $ cp .env_example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_TITLE=Liver Care Chatbot
APP_VERSION=2.0.0

# ── OpenRouter LLM API ────────────────────────────────────────────────────────
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Base URL for OpenRouter API (usually stays the same)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default LLM model to use
# Examples: google/gemini-2.5-flash-lite, openai/gpt-4o, anthropic/claude-opus
DEFAULT_MODEL=google/gemini-2.5-flash-lite

# Maximum tokens per response (constraint from model)
MAX_TOKENS=700

# Temperature controls randomness (0.0 = deterministic, 1.0 = random)
TEMPERATURE=0.4

# Number of conversation turns to keep in history
MAX_HISTORY_TURNS=20

# ── Server ────────────────────────────────────────────────────────────────────
# Server host (0.0.0.0 = accessible from any IP, 127.0.0.1 = localhost only)
APP_HOST=0.0.0.0

# Server port
APP_PORT=8000

# Debug mode (set to true for development, false for production)
DEBUG=False

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins for cross-origin requests (comma-separated)
# Use "*" for development (NOT recommended for production)
# Example: http://localhost:3000,http://localhost:5173,https://example.com
ALLOWED_ORIGINS=*
